# ─── Production: https://impact.buffindia.com ───
# Set all variables in Vercel → Project → Settings → Environment Variables

# Public site URL (used for SEO, emails, absolute links)
NEXT_PUBLIC_APP_URL="https://impact.buffindia.com"

# Required – Neon PostgreSQL (use pooled connection string)
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"

# Admin panel password (cookie auth for /admin)
ADMIN_PASSWORD="your-secure-admin-password"

# Admin OTP reset email
ADMIN_EMAIL="admin@buffindia.com"

# Session signing secret — run: openssl rand -base64 32
AUTH_SECRET="generate-a-long-random-string"

# Resend (password reset OTP + support ticket emails)
RESEND_API_KEY=""
RESEND_FROM="Buffindia <noreply@buffindia.com>"

# Optional – Google Sheets import
GOOGLE_SHEET_ID=""
GOOGLE_API_KEY=""
