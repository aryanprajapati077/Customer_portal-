# Copy to Vercel: Project → Settings → Environment Variables (all environments)

# Required – Neon PostgreSQL connection string (pooled URL recommended for serverless)
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"

# Admin panel password (cookie auth for /admin and /api/admin/*)
ADMIN_PASSWORD="your-secure-admin-password"

# Optional – Resend for transactional email
RESEND_API_KEY=""
RESEND_FROM="Buffindia <no-reply@buffindia.com>"

# Optional – Google Sheets sync (if used)
GOOGLE_SHEET_ID=""
GOOGLE_API_KEY=""
