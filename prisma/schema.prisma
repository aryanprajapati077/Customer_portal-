// Prisma Schema for Buffindia ESG Platform
// Optimized for Prisma 7 with Neon Serverless

generator client {
  provider = "prisma-client"
  output   = "../lib/prisma-client"
}


datasource db {
  provider = "postgresql"
}

model Customer {
  id                  String        @id @default(cuid())
  email               String        @unique
  password            String
  companyName         String
  contactPerson       String?
  phone               String?
  address             String?
  industry            String?
  employeeCount       Int?          @default(0)
  joinDate            DateTime      @default(now())
  status              String        @default("Active")
  disposalUnitInstalled Int         @default(0)
  
  // Group / Parent-Child: Group clients can access all child companies
  isGroup             Boolean       @default(false)
  parentCustomerId    String?
  parentCustomer      Customer?     @relation("CustomerHierarchy", fields: [parentCustomerId], references: [id], onDelete: SetNull)
  childCustomers      Customer[]    @relation("CustomerHierarchy")
  
  // Impact Metrics
  totalWasteCollected Float         @default(0)
  cigaretteButtsCollected Float     @default(0)
  microplasticsUpcycled Float       @default(0)
  waterResourcesProtected Float     @default(0)
  pendingCollection   Float         @default(0)
  certificatesEarned  Int           @default(0)
  co2Saved            Float         @default(0)
  kraftrebornCredits  Float         @default(0)
  treesEquivalent     Int           @default(0)
  monthlyTarget       Float         @default(0)
  
  profileImageUrl     String?
  notes               String?
  
  // Relations
  collections         Collection[]
  certificates        Certificate[]
  reports             Report[]
  notifications       Notification[]
  shopOrders          ShopOrder[]
  
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  @@index([email])
}

model Notification {
  id         String   @id @default(cuid())
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  title      String
  body       String?
  linkUrl    String?
  readAt     DateTime?
  createdAt  DateTime @default(now())

  @@index([customerId])
  @@index([createdAt])
  @@index([readAt])
}

model Collection {
  id             String   @id @default(cuid())
  customerId     String
  customer       Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  date           DateTime @default(now())
  weight         Float
  location       String?
  status         String   @default("Completed")
  co2Saved       Float?
  collectorName  String?
  vehicleNumber  String?
  notes          String?

  @@index([customerId])
  @@index([date])
}

model Certificate {
  id                String   @id @default(cuid())
  customerId        String
  customer          Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  name              String
  issueDate         DateTime @default(now())
  type              String?
  description       String?
  driveFileUrl      String?
  validUntil        String?
  issuedBy          String   @default("Buffindia")
  certificateNumber String   @unique

  @@index([customerId])
}

model Report {
  id           String   @id @default(cuid())
  customerId   String
  customer     Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  name         String
  date         DateTime @default(now())
  type         String?
  driveFileUrl String?
  size         String?
  description  String?
  period       String?
  generatedBy  String?

  @@index([customerId])
  @@index([date])
}

// System-wide Aggregate Metrics for Homepage
model GlobalImpact {
  id               String   @id @default("global-impact")
  wasteCollected   Float    @default(0)
  productsCreated  Float    @default(0)
  treesEquivalent  Int      @default(0)
  co2Prevented     Float    @default(0)
  updatedAt        DateTime @updatedAt
}

model Product {
  id            String      @id @default(cuid())
  name          String
  description   String
  price         Float
  category      String      @default("elegant-combos")
  tagline       String?
  buttsRescued  Int         @default(40)
  imageUrl      String?
  imageGradient String      @default("from-amber-100 via-stone-200 to-emerald-100")
  allowsLogo    Boolean     @default(false)
  active        Boolean     @default(true)
  sortOrder     Int         @default(0)
  orderItems    OrderItem[]
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@index([category])
  @@index([active])
}

model ShopOrder {
  id              String      @id @default(cuid())
  orderNumber     String      @unique
  customerId      String
  customer        Customer    @relation(fields: [customerId], references: [id], onDelete: Cascade)
  status          String      @default("pending")
  subtotal        Float
  useKrCredits    Boolean     @default(true)
  creditsDeducted Boolean     @default(false)
  logoRequested   Boolean     @default(false)
  logoUrl         String?
  shippingName    String?
  shippingEmail   String?
  shippingPhone   String?
  shippingAddress String?
  notes           String?
  items           OrderItem[]
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  completedAt     DateTime?

  @@index([customerId])
  @@index([status])
  @@index([createdAt])
}

model OrderItem {
  id          String    @id @default(cuid())
  orderId     String
  order       ShopOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId   String?
  product     Product?  @relation(fields: [productId], references: [id], onDelete: SetNull)
  productName String
  price       Float
  quantity    Int
  allowsLogo  Boolean   @default(false)

  @@index([orderId])
}

model PasswordResetOtp {
  id         String    @id @default(cuid())
  email      String
  purpose    String    @default("customer")
  otpHash    String
  resetToken String?   @unique
  expiresAt  DateTime
  verifiedAt DateTime?
  usedAt     DateTime?
  attempts   Int       @default(0)
  createdAt  DateTime  @default(now())

  @@index([email, purpose])
}

model AdminCredential {
  id           String   @id @default("admin")
  email        String
  passwordHash String
  updatedAt    DateTime @updatedAt
}

model VerifiedCertificate {
  id         String   @id @default(cuid())
  title      String
  issuer     String
  validUntil String
  type       String
  icon       String   @default("shield")
  pdfUrl     String?
  sortOrder  Int      @default(0)
  active     Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([active])
}

model SupportTicket {
  id         String   @id @default(cuid())
  customerId String?
  name       String
  email      String
  subject    String
  message    String
  category   String   @default("general")
  status     String   @default("open")
  source     String   @default("chatbot")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([status])
  @@index([email])
  @@index([createdAt])
}
